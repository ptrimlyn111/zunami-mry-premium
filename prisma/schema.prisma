generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum ServiceCategory {
  TRADITIONAL_DANCE
  MODERN_DANCE
  MAKEUP_ARTIST
  DANCE_ACADEMY
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  accounts  Account[]
  sessions  Session[]
}

model Booking {
  id           String        @id @default(cuid())
  orderId      String        @unique
  customerName String
  whatsapp     String
  service      String
  eventDate    DateTime
  location     String
  notes        String?
  status       BookingStatus @default(PENDING)
  createdAt    DateTime      @default(now())
  payment      Payment?
}

model Service {
  id          String          @id @default(cuid())
  title       String
  description String
  price       Int
  image       String
  category    ServiceCategory
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model Class {
  id        String   @id @default(cuid())
  title     String
  schedule  String
  level     String
  quota     Int
  createdAt DateTime @default(now())
}

model Payment {
  id            String        @id @default(cuid())
  bookingId     String        @unique
  booking       Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  amount        Int
  status        PaymentStatus @default(UNPAID)
  paymentMethod String?
  createdAt     DateTime      @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}
